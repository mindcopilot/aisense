# ===== API server =====
PORT=4000
NODE_ENV=development

# ===== PostgreSQL =====
DATABASE_URL=postgres://looma:looma@localhost:5432/looma

# ===== Temporal =====
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=looma-photoshoot

# ===== LLM (Vercel AI SDK) =====
# Recommended LLM base library: the Vercel AI SDK ("ai" package).
# Leave ANTHROPIC_API_KEY blank to use the built-in deterministic fallback.
ANTHROPIC_API_KEY=
LLM_CHAT_MODEL=claude-sonnet-4-6
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_IMAGE_MODEL=looma-director-v3

# ===== Langfuse (LLM observability) =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ===== Web =====
VITE_API_BASE_URL=http://localhost:4000
